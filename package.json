{
  "name": "clawpatch-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/ensure-electron.mjs && electron-vite dev",
    "build": "electron-vite build",
    "dist": "pnpm build && electron-builder",
    "preview": "node scripts/ensure-electron.mjs && electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "update": "pnpm up -i -L && node scripts/ensure-electron.mjs",
    "check": "turbo run typecheck lint fmt test",
    "check:ci": "turbo run typecheck lint fmt:check test build",
    "clean": "rm -rf out release .turbo",
    "ensure:electron": "node scripts/ensure-electron.mjs"
  },
  "dependencies": {
    "@effect/platform-node": "beta",
    "@pierre/diffs": "^1.2.3",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.8",
    "effect": "beta",
    "lucide-react": "^1.16.0",
    "pino": "^10.3.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@effect/vitest": "beta",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "turbo": "^2.9.15",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": "24.16.0"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "build": {
    "appId": "ai.clawpatch.ui",
    "productName": "Clawpatch UI",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/build-assets/icons/icon-512.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/build-assets/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/build-assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Development",
      "icon": "resources/build-assets/icons",
      "target": [
        "AppImage"
      ]
    }
  },
  "productName": "Clawpatch UI"
}
