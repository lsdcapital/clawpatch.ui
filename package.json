{
  "name": "clawpatch-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "update": "pnpm up -i -L",
    "check": "turbo run typecheck lint fmt:check test",
    "check:ci": "turbo run typecheck lint fmt:check test build",
    "clean": "rm -rf out .turbo"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/view": "^6.43.0",
    "@effect/platform-node": "4.0.0-beta.68",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.4",
    "@uiw/react-codemirror": "^4.25.3",
    "effect": "4.0.0-beta.68",
    "lucide-react": "^1.16.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.68",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.1.0",
    "electron-vite": "^4.0.0",
    "jsdom": "^27.3.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.65.0",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@11.1.3"
}
